# Example environment configuration for TokenBalanceAndTransfer script
# Copy this file to .env and fill in your actual values

# RPC URL for the Ethereum network
# Examples:
# - Mainnet: https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# - Goerli: https://eth-goerli.g.alchemy.com/v2/YOUR_API_KEY
# - Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# - Local: http://localhost:8545
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Authentication - Use either PRIVATE_KEY or MNEMONIC (not both)
# PRIVATE_KEY=0x1234567890abcdef...
# MNEMONIC="your twelve word mnemonic phrase here"

# Top 5 token addresses to check balances
# These are examples for Ethereum mainnet - replace with your actual tokens
TOKEN1=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2  # WETH (Wrapped Ether)
TOKEN2=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48  # USDC
TOKEN3=0xdAC17F958D2ee523a2206206994597C13D831ec7  # USDT
TOKEN4=0x6B175474E89094C44Da98b954EedeAC495271d0F  # DAI
TOKEN5=0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599  # WBTC

# Token to transfer (must be one you own/control)
# This should be the contract address of the ERC20 token
TOKEN_TO_TRANSFER=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2  # Example: WETH

# Recipient address for the new wormhole address
# This is where tokens will be transferred
# ⚠️ WARNING: DO NOT USE THE ZERO ADDRESS - REPLACE WITH YOUR ACTUAL ADDRESS
# Using 0x0000000000000000000000000000000000000000 will cause transaction to fail
RECIPIENT_ADDRESS=0xREPLACE_WITH_YOUR_ACTUAL_RECIPIENT_ADDRESS

# Amount to transfer (in wei for 18-decimal tokens)
# Examples:
# - 1 token (18 decimals): 1000000000000000000
# - 0.1 token (18 decimals): 100000000000000000
# - 1000 tokens (18 decimals): 1000000000000000000000
TRANSFER_AMOUNT=1000000000000000000

# Authorization flag - MUST be "true" to allow distribution
# This is the Kushmanmb authorization requirement
# Set to "true" to explicitly authorize the transfer
# Set to "false" (or leave unset) to only check balances without transferring
KUSHMANMB_AUTHORIZED=false

# Optional: Additional forge arguments
# FORGE_ARGS="--legacy --gas-price 20000000000"
